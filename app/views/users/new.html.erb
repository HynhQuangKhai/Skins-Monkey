<div class="auth-container">
  <div class="auth-box">
    <h1>Create Account</h1>
    <p class="auth-subtitle">Join SkinsMonkey today</p>
    
    <%= form_with model: @user, url: signup_path, class: "auth-form" do |f| %>
      <% if @user.errors.any? %>
        <div class="error-messages">
          <h4>Please fix the following errors:</h4>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      
      <div class="form-group">
        <%= f.label :username, "Username" %>
        <%= f.text_field :username, class: "form-control", required: true, placeholder: "Your username" %>
      </div>
      
      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, class: "form-control", required: true, placeholder: "your@email.com" %>
      </div>
      
      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", required: true, placeholder: "Min. 6 characters" %>
      </div>
      
      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, class: "form-control", required: true, placeholder: "Confirm password" %>
      </div>
      
      <%= f.submit "Create Account", class: "btn btn-primary btn-full" %>
    <% end %>
    
    <div class="auth-links">
      <p>Already have an account? <%= link_to "Login here", login_path %></p>
    </div>
  </div>
</div>
