<div class="profile-container">
  <div class="profile-header">
    <div class="profile-avatar">
      <%= @user.username[0].upcase %>
    </div>
    <div class="profile-info">
      <h1><%= @user.username %></h1>
      <p><%= @user.email %></p>
      <p class="balance">Balance: <%= number_to_currency(@user.balance) %></p>
    </div>
  </div>
  
  <div class="profile-sections">
    <div class="section">
      <h2>Recent Orders</h2>
      <% if @orders.any? %>
        <div class="orders-list">
          <% @orders.each do |order| %>
            <div class="order-card">
              <div class="order-info">
                <span class="order-id">Order #<%= order.id %></span>
                <span class="order-date"><%= order.formatted_date %></span>
              </div>
              <div class="order-details">
                <span class="order-total"><%= order.display_total %></span>
                <span class="order-status <%= order.status_class %>"><%= order.status.titleize %></span>
              </div>
              <%= link_to "View Details", order_path(order), class: "btn btn-sm btn-outline" %>
            </div>
          <% end %>
        </div>
        <%= link_to "View All Orders", orders_path, class: "btn btn-outline" %>
      <% else %>
        <p class="empty-state">No orders yet. <%= link_to "Start shopping!", products_path %></p>
      <% end %>
    </div>
    
    <div class="section">
      <h2>Wishlist</h2>
      <% if @wishlist.any? %>
        <div class="wishlist-preview">
          <% @wishlist.limit(3).each do |item| %>
            <div class="wishlist-item">
              <%= image_tag item.product.image_url || '/images/default_skin.png', class: 'wishlist-thumb' %>
              <span class="wishlist-name"><%= item.product.name %></span>
              <span class="wishlist-price"><%= item.product.display_price %></span>
            </div>
          <% end %>
        </div>
        <%= link_to "View Full Wishlist", wishlist_path, class: "btn btn-outline" %>
      <% else %>
        <p class="empty-state">Your wishlist is empty. <%= link_to "Browse skins!", products_path %></p>
      <% end %>
    </div>
  </div>
</div>
