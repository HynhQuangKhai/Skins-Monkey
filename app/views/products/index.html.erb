<div class="products-page">
  <div class="products-header">
    <h1>CS2 Skins Marketplace</h1>
    <p>Discover the best CS2 skins at competitive prices</p>
  </div>
  
  <div class="products-layout">
    <aside class="filters-sidebar">
      <h3>Filters</h3>
      <%= form_with url: products_path, method: :get, class: "filters-form" do |f| %>
        <div class="filter-group">
          <%= f.label :rarity, "Rarity" %>
          <%= f.select :rarity, options_for_select(Product::RARITIES.map { |r| [r.titleize, r] }, params[:rarity]), 
                      { include_blank: "All Rarities" }, { class: "form-control" } %>
        </div>
        
        <div class="filter-group">
          <%= f.label :category, "Category" %>
          <%= f.select :category, options_for_select(Product::CATEGORIES.map { |c| [c.titleize, c] }, params[:category]), 
                      { include_blank: "All Categories" }, { class: "form-control" } %>
        </div>
        
        <div class="filter-group price-range">
          <%= f.label :price_range, "Price Range" %>
          <div class="price-inputs">
            <%= f.number_field :min_price, value: params[:min_price], placeholder: "Min", class: "form-control", step: 0.01 %>
            <%= f.number_field :max_price, value: params[:max_price], placeholder: "Max", class: "form-control", step: 0.01 %>
          </div>
        </div>
        
        <div class="filter-group">
          <%= f.label :sort, "Sort By" %>
          <%= f.select :sort, options_for_select([
            ["Newest", ""],
            ["Price: Low to High", "price_low"],
            ["Price: High to Low", "price_high"],
            ["Name", "name"]
          ], params[:sort]), {}, { class: "form-control" } %>
        </div>
        
        <%= f.submit "Apply Filters", class: "btn btn-primary btn-sm" %>
        <%= link_to "Clear", products_path, class: "btn btn-outline btn-sm" %>
      <% end %>
    </aside>
    
    <div class="products-grid-container">
      <% if @products.any? %>
        <div class="products-grid">
          <% @products.each do |product| %>
            <div class="product-card">
              <div class="product-image">
                <%= image_tag product.image_url || '/images/default_skin.png', alt: product.name %>
                <div class="product-rarity" style="background-color: <%= product.rarity_color %>">
                  <%= product.rarity.titleize %>
                </div>
                <% if product.wear.present? %>
                  <div class="product-wear"><%= product.wear.titleize %></div>
                <% end %>
              </div>
              <div class="product-info">
                <h3 class="product-name"><%= link_to product.name, product_path(product) %></h3>
                <p class="product-price"><%= product.display_price %></p>
                <div class="product-actions">
                  <%= button_to add_to_cart_path(product_id: product.id), class: "btn btn-primary btn-sm" do %>
                    Add to Cart
                  <% end %>
                  <%= button_to add_to_wishlist_path(product_id: product.id), class: "btn btn-outline btn-sm" do %>
                    ❤️
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>No products found matching your criteria.</p>
          <%= link_to "Clear Filters", products_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
