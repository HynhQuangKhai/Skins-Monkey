<div class="order-detail-page">
  <div class="order-header">
    <h1>Order #<%= @order.id %></h1>
    <div class="order-meta">
      <span class="order-date"><%= @order.formatted_date %></span>
      <span class="status-badge <%= @order.status_class %>"><%= @order.status.titleize %></span>
    </div>
  </div>
  
  <div class="order-detail-layout">
    <div class="order-items-section">
      <h2>Items</h2>
      <div class="order-items-list">
        <% @order_items.each do |item| %>
          <div class="order-item">
            <%= image_tag item.product.image_url || '/images/default_skin.png', class: 'order-item-image' %>
            <div class="order-item-details">
              <h4><%= item.product.name %></h4>
              <span class="rarity-tag" style="background-color: <%= item.product.rarity_color %>">
                <%= item.product.rarity.titleize %>
              </span>
            </div>
            <div class="order-item-pricing">
              <span class="unit-price"><%= item.display_price %> × <%= item.quantity %></span>
              <span class="item-total"><%= item.display_total %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="order-summary-section">
      <h2>Order Summary</h2>
      <div class="summary-card">
        <div class="summary-row">
          <span>Subtotal</span>
          <span><%= @order.display_total %></span>
        </div>
        <div class="summary-row">
          <span>Service Fee</span>
          <span>Free</span>
        </div>
        <div class="summary-row total">
          <span>Total</span>
          <span><%= @order.display_total %></span>
        </div>
        
        <div class="order-info">
          <h4>Payment Method</h4>
          <p><%= @order.payment_method&.titleize || "N/A" %></p>
          
          <h4>Delivery Information</h4>
          <p class="trade-url"><%= @order.shipping_address %></p>
        </div>
      </div>
    </div>
  </div>
  
  <div class="order-actions">
    <%= link_to "← Back to Orders", orders_path, class: "btn btn-outline" %>
    <%= link_to "Continue Shopping", products_path, class: "btn btn-primary" %>
  </div>
</div>
