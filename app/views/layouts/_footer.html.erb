<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h4>SkinsMonkey</h4>
      <p>The best place to buy and sell CS2 skins safely and securely.</p>
    </div>
    
    <div class="footer-section">
      <h4>Quick Links</h4>
      <%= link_to "Browse Skins", products_path %>
      <%= link_to "My Cart", cart_path %>
      <%= link_to "My Wishlist", wishlist_path %>
    </div>
    
    <div class="footer-section">
      <h4>Account</h4>
      <% if logged_in? %>
        <%= link_to "My Profile", user_path(current_user) %>
        <%= link_to "Order History", orders_path %>
        <%= button_to "Logout", logout_path, method: :delete %>
      <% else %>
        <%= link_to "Login", login_path %>
        <%= link_to "Sign Up", signup_path %>
      <% end %>
    </div>
    
    <div class="footer-section">
      <h4>Contact</h4>
      <p>support@skinsmonkey.com</p>
      <p>&copy; 2024 SkinsMonkey. All rights reserved.</p>
    </div>
  </div>
</footer>
