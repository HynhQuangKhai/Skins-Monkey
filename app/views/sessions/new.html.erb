<div class="auth-container">
  <div class="auth-box">
    <h1>Welcome Back</h1>
    <p class="auth-subtitle">Login to your SkinsMonkey account</p>
    
    <%= form_with url: login_path, method: :post, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, class: "form-control", required: true, placeholder: "your@email.com" %>
      </div>
      
      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", required: true, placeholder: "••••••••" %>
      </div>
      
      <%= f.submit "Login", class: "btn btn-primary btn-full" %>
    <% end %>
    
    <div class="auth-links">
      <p>Don't have an account? <%= link_to "Sign up here", signup_path %></p>
    </div>
  </div>
</div>
